#!/bin/bash
# 获取AppImage自动挂载后的根目录（不解包也能正常获取）
HERE="$(dirname "$(readlink -f "$0")")"

# Qt插件搜索路径，优先包内自带插件
export QT_PLUGIN_PATH="$HERE/plugins:$QT_PLUGIN_PATH"
# 动态库同时检索外层lib + 输入法插件目录，解决ibus依赖找不到问题
export LD_LIBRARY_PATH="$HERE/lib:$HERE/plugins/platforminputcontexts:$LD_LIBRARY_PATH"

# 不覆盖用户系统输入法环境，仅无配置时默认fcitx5
if [ -z "$QT_IM_MODULE" ]; then
    export QT_IM_MODULE=fcitx5
    export XMODIFIERS=@im=fcitx5
fi

exec "$HERE/Knot" "$@"
