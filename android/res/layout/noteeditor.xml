<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:layout_weight="1"
    android:orientation="vertical"
>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="66dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
    >

        <Button
            android:id="@+id/btn_cancel"
            android:textAllCaps="false"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="Close"
        />

        <Button
            android:id="@+id/btn_save"
            android:textAllCaps="false"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="Save"
        />

        <Button
            android:id="@+id/btnFind"
            android:textAllCaps="false"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="Find"
        />

        <Button
            android:id="@+id/btnUndo"
            android:textAllCaps="false"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="Undo"
        />

        <Button
            android:id="@+id/btnRedo"
            android:textAllCaps="false"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="Redo"
        />

        <View
            android:id="@+id/preview_selected_color"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:background="@android:color/darker_gray"
        />

        <Button
            android:id="@+id/btnMenu"
            android:textAllCaps="false"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:text="Menu"
        />

    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal"
    >

    <!-- R 按钮：显示/隐藏替换 -->
    <Button
            android:id="@+id/btnToggleReplace"
            android:layout_width="55dp"
            android:layout_height="match_parent"
            android:textAllCaps="false"
            android:layout_marginTop="1dp"
            android:layout_weight="1"
            android:text="R"
        />

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="55dp"
            android:layout_height="match_parent"
            android:textAllCaps="false"
            android:layout_marginTop="1dp"
            android:layout_weight="1"
            android:text="Prev"
        />

        <EditText
            android:id="@+id/editFind"
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:layout_marginTop="1dp"
            android:layout_marginRight="10dp"
            android:layout_marginLeft="10dp"
            android:text=""
            android:imeOptions="actionGo"
            android:textColor="#000000"
            android:scrollbars="vertical"
            android:fadeScrollbars="true"
            android:singleLine="true"
            android:layout_weight="1"
        />

        <ImageButton
            android:id="@+id/btnStartFind"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:background="@drawable/shape_blue_button"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:layout_gravity="center_vertical"
            android:src="@drawable/find_l"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
        />

        <TextView
            android:id="@+id/lblResult"
            android:layout_width="65dp"
            android:layout_height="50dp"
            android:layout_marginTop="1dp"
            android:layout_marginRight="10dp"
            android:layout_marginLeft="10dp"
            android:text=""
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:scrollbars="vertical"
            android:fadeScrollbars="true"
            android:inputType="textMultiLine"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_gravity="center_vertical"
        />


        <Button
            android:id="@+id/btnNext"
            android:layout_width="55dp"
            android:layout_height="match_parent"
            android:textAllCaps="false"
            android:layout_marginTop="1dp"
            android:layout_weight="1"
            android:text="Next"
        />


    </LinearLayout>

    <!-- ============================================== -->
    <!-- 替换功能 UI  -->
    <!-- ============================================== -->
    <LinearLayout
        android:id="@+id/replaceLayout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:visibility="gone"
    >

        <!-- 第一行：替换输入框 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
        >

            <TextView
                android:id="@+id/lblReplace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text="Replace:"
                android:textColor="#000000"
                android:textSize="14sp"
            />

            <EditText
                android:id="@+id/editReplace"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:singleLine="true"
                android:text=""
                android:textColor="#000000"
            />

        </LinearLayout>

        <!-- 第二行：三个按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:weightSum="3"
        >

            <Button
                android:id="@+id/btnReplace"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Replace"
                android:textAllCaps="false"
            />

            <Button
                android:id="@+id/btnReplaceFind"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Replace &amp; Find"
                android:textAllCaps="false"
            />

            <Button
                android:id="@+id/btnReplaceAll"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Replace All"
                android:textAllCaps="false"
            />

        </LinearLayout>

    </LinearLayout>

    <!-- 内容区域：用 FrameLayout 包裹 ScrollView 和进度条 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
    >

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:scrollbars="vertical"
            android:fadeScrollbars="true"
            android:layout_marginTop="5dp"
            android:layout_marginRight="16dp"
            android:layout_marginLeft="0dp"
        />

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:scrollbars="vertical"
            android:fadeScrollbars="true"
        >
            <com.x.LineNumberedEditText
                android:id="@+id/editNote"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="5dp"
                android:layout_marginRight="16dp"
                android:layout_marginLeft="0dp"
                android:text="Loading, please wait..."
                android:textColor="#000000"
                android:inputType="textMultiLine"
                android:layout_weight="1"
            />
        </ScrollView>


        <!-- 覆盖在内容上的进度条 -->
        <!--ProgressBar
         android:id="@+id/progressBar"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:layout_gravity="center"
         android:visibility="gone"/-->

        <!-- 带背景的进度容器 -->
        <FrameLayout
            android:id="@+id/progressContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/progress_card_bg"
            android:elevation="8dp"
            android:visibility="gone"
            android:padding="24dp"
        >

            <!-- 放大后的圆圈进度 -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:indeterminateTint="#FF4081"
                android:theme="@style/CircularProgressStyle"
            />

        </FrameLayout>
    </FrameLayout>

</LinearLayout>
