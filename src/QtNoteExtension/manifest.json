{
  "manifest_version": 3,
  "name": "Knot 笔记同步",
  "version": "1.0.0",
  "description": "将网页选中内容保存到 Knot 笔记",
  "permissions": [
    "contextMenus",
    "nativeMessaging",
    "storage",
    "scripting"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "knot-sync@debug.local",
      "strict_min_version": "91.0"
    }
  }
}